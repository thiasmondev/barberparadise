# ─── Base de données ─────────────────────────────────────────
# PostgreSQL — utiliser l'URL interne Render pour la prod (plus rapide, réseau privé)
DATABASE_URL=postgresql://user:PASSWORD@host/dbname

# ─── Authentification JWT ────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
ADMIN_JWT_SECRET=your-admin-jwt-secret-min-32-chars

# ─── Intelligence Artificielle ───────────────────────────────
# Clé API Anthropic Claude — générer sur console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Cloudinary (stockage images) ────────────────────────────
# Identifiants disponibles sur cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Serveur ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Frontend (variables publiques Next.js) ──────────────────
# Préfixe NEXT_PUBLIC_ = exposé côté client (ne jamais y mettre de secrets)
NEXT_PUBLIC_API_URL=https://barberparadise-backend.onrender.com
CORS_ORIGIN=https://barberparadise.vercel.app

# ─── Paiements multi-PSP ───────────────────────────────────────
# URL publique du frontend utilisée pour les retours succès/annulation PSP
FRONTEND_URL=https://barberparadise.vercel.app

# Mollie — cartes, virements bancaires, SEPA et moyens de paiement locaux EEE
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_WEBHOOK_SECRET=replace-with-random-webhook-secret

# PayPal — PayPal 4x pour clients B2C éligibles
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Checkout.com — cartes internationales hors EEE
CHECKOUT_SECRET_KEY=sk_sbox_xxxxxxxxxxxxxxxxxxxxx
CHECKOUT_PUBLIC_KEY=pk_sbox_xxxxxxxxxxxxxxxxxxxxx
CHECKOUT_ENV=sandbox
CHECKOUT_WEBHOOK_SECRET=replace-with-random-webhook-secret

# ─── Logistique transporteurs (étiquettes officielles) ───────────
# Adresse expéditeur utilisée par Colissimo et Mondial Relay
LOGISTICS_SENDER_COMPANY=Barber Paradise
LOGISTICS_SENDER_ADDRESS=12 rue Exemple
LOGISTICS_SENDER_ADDRESS_2=
LOGISTICS_SENDER_POSTAL_CODE=75000
LOGISTICS_SENDER_CITY=Paris
LOGISTICS_SENDER_PHONE=0100000000
LOGISTICS_SENDER_EMAIL=contact@barberparadise.fr

# Colissimo SLS — création d'étiquettes officielles
COLISSIMO_API_KEY=your-colissimo-api-key
COLISSIMO_SLS_ENDPOINT=https://ws.colissimo.fr/sls-ws/SlsServiceWS/2.0

# Mondial Relay SOAP — création d'expéditions et récupération d'étiquettes
MONDIAL_RELAY_ENSEIGNE=your-mondial-relay-brand-code
MONDIAL_RELAY_PRIVATE_KEY=your-mondial-relay-private-key
MONDIAL_RELAY_MODE_COL=CCC
MONDIAL_RELAY_MODE_LIV=24R
# Optionnel : grille contractuelle Mondial Relay en centimes, si Barber Paradise reçoit une grille dédiée.
# Exemple ci-dessous : 3,59 € jusqu'à 500 g.
# LOGISTICS_MONDIAL_RELAY_TARIFFS_JSON=[{"maxWeightG":500,"amountCents":359}]
