// ============================================================
// BARBER PARADISE — Schéma Prisma (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PRODUITS ────────────────────────────────────────────────
model Product {
  id                    String   @id @default(cuid())
  handle                String   @unique
  name                  String
  slug                  String   @unique
  brand                 String
  brandId               Int?
  category              String
  subcategory           String
  subsubcategory        String   @default("")
  price                 Float
  priceProEur           Float? // Prix pro HT — null = même prix que B2C
  originalPrice         Float?
  compareAtPrice        Float? // Prix de base barré
  purchasePrice         Float? // Prix d'achat confidentiel
  images                String // JSON array
  imageAlts             String   @default("[]") // JSON array of alt texts matching images order
  description           String
  shortDescription      String
  features              String   @default("[]") // JSON array
  inStock               Boolean  @default(true)
  stockCount            Int      @default(0)
  weightG               Int? // Poids en grammes
  lengthCm              Float? // Longueur cm
  widthCm               Float? // Largeur cm
  heightCm              Float? // Hauteur cm
  isFragile             Boolean  @default(false)
  isLiquid              Boolean  @default(false)
  isAerosol             Boolean  @default(false)
  requiresGlass         Boolean  @default(false)
  logisticNote          String? // Note spéciale ex: "ne pas coucher"
  rating                Float    @default(0)
  reviewCount           Int      @default(0)
  isNew                 Boolean  @default(false)
  isPromo               Boolean  @default(false)
  tags                  String   @default("[]") // JSON array
  status                String   @default("active") // active, draft, archived
  categoryOrder         Int      @default(0)
  recommendedProductIds String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  brandRef   Brand?           @relation(fields: [brandId], references: [id])
  orderItems OrderItem[]
  reviews    Review[]
  variants   ProductVariant[]
  stockAlerts StockAlert[]

  @@index([category])
  @@index([subcategory])
  @@index([brand])
  @@index([brandId])
  @@index([status])
  @@index([categoryOrder])
}

// ─── EMBALLAGES LOGISTIQUES ───────────────────────────────────

model AbandonedCartSession {
  id               String    @id
  email            String?
  items            Json
  itemCount        Int       @default(0)
  total            Float     @default(0)
  convertedOrderId String?
  convertedAt      DateTime?
  reminderStage    Int       @default(0)
  lastReminderAt   DateTime?
  unsubscribed     Boolean   @default(false)
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([lastSeenAt])
  @@index([convertedAt])
  @@index([reminderStage])
  @@index([unsubscribed])
}

model ShippingZone {
  id        String         @id @default(cuid())
  name      String
  countries String[]
  rates     ShippingRate[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([name])
}

model ShippingRate {
  id            String       @id @default(cuid())
  zoneId        String
  zone          ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name          String
  minAmount     Float        @default(0)
  maxAmount     Float?
  price         Float
  carrier       String?
  freeThreshold Float?
  isFree        Boolean      @default(false)
  deliveryTime  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([zoneId])
  @@index([minAmount])
  @@index([carrier])
}

// ─── CARROUSEL PAGE D’ACCUEIL ───────────────────────────────
model CarouselSlide {
  id              String   @id @default(cuid())
  title           String?
  subtitle        String?
  description     String?  @db.Text
  imageUrl        String
  imageMobileUrl  String?
  imageAlt        String?
  cloudinaryId    String?
  mobileCloudinaryId String?
  ctaText         String?
  ctaLink         String?
  ctaStyle        String?  @default("primary")
  textPosition    String   @default("left")
  textColor       String   @default("#FFFFFF")
  overlayOpacity  Float    @default(0.3)
  isActive        Boolean  @default(true)
  startDate       DateTime?
  endDate         DateTime?
  position        Int      @default(0)
  category        String   @default("general")
  createdBy       String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([position])
  @@index([startDate, endDate])
  @@index([category])
}

model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt
}

model Packaging {
  id                Int     @id @default(autoincrement())
  name              String // ex: "Carton S", "Enveloppe bulle", "Carton renforcé L"
  type              String // 'carton', 'enveloppe', 'tube'
  lengthCm          Float
  widthCm           Float
  heightCm          Float
  internalVolumeCm3 Float // volume utile calculé
  maxWeightG        Int // poids max supporté
  selfWeightG       Int // poids du carton vide
  costEur           Float // coût unitaire du carton
  stock             Int     @default(0)
  isReinforced      Boolean @default(false)
  isActive          Boolean @default(true)

  shipments Shipment[]
}

// ─── MARQUES ─────────────────────────────────────────────────
model Brand {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  bannerImage String?
  website     String?
  createdAt   DateTime @default(now())

  products Product[]
}

// ─── VARIANTES PRODUIT ────────────────────────────────────────────
model ProductVariant {
  id          String  @id @default(cuid())
  productId   String
  name        String // ex: "Rouge", "L", "Rouge / L"
  type        String // "color" | "size" | "other"
  color       String  @default("") // nom de la couleur
  colorHex    String  @default("") // code hexa ex: #FF0000
  size        String  @default("") // ex: "S", "M", "L", "XL"
  price         Float? // si null, utilise le prix du produit parent
  priceProEur   Float? // Prix pro HT — null = utilise le prix pro du produit parent
  purchasePrice Float? // Prix d'achat confidentiel par variante
  stock         Int     @default(0)
  inStock     Boolean @default(true)
  sku         String  @default("")
  image       String  @default("") // image spécifique à la variante
  order       Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  stockAlerts StockAlert[]

  @@index([productId])
}


model StockAlert {
  id        String   @id @default(cuid())
  email     String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
  notifiedAt DateTime?

  @@unique([email, productId, variantId])
  @@index([productId, variantId, notified])
  @@index([email])
  @@index([createdAt])
}

// ─── CLIENTS ─────────────────────────────────────────────────
model Customer {
  id                    String   @id @default(cuid())
  email                 String   @unique
  password              String
  firstName             String
  lastName              String
  phone                 String?
  mustResetPassword     Boolean  @default(false)
  acceptsEmailMarketing Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  addresses           Address[]
  orders              Order[]
  wishlist            WishlistItem[]
  passwordResetTokens PasswordResetToken[]
  proAccount          ProAccount?
  extraEmails         CustomerEmail[]
}

// Emails secondaires d'un client (facturation, comptabilité, direction...)
model CustomerEmail {
  id         String   @id @default(cuid())
  customerId String
  email      String
  label      String   @default("Secondaire") // ex: "Facturation", "Comptabilité", "Direction"
  isPrimary  Boolean  @default(false)         // true = email de facturation par défaut
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, email])
  @@index([customerId])
}

model ProAccount {
  id              String    @id @default(cuid())
  customerId      String    @unique
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  companyName     String
  siret           String?
  vatNumber       String?
  activity        String
  phone           String
  status          String    @default("pending") // pending, approved, rejected
  rejectionReason String?
  approvedAt      DateTime?
  approvedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─── ADRESSES ────────────────────────────────────────────────
model Address {
  id         String   @id @default(cuid())
  customerId String
  firstName  String
  lastName   String
  address    String
  extension  String?  @default("")
  city       String
  postalCode String
  country    String   @default("France")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ─── COMMANDES ───────────────────────────────────────────────
model Order {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  customerId        String?
  email             String
  status            String   @default("pending") // draft, pending, pending_payment, paid, processing, shipped, delivered, cancelled, refunded, partially_refunded
  paymentMethod     String   @default("card")
  paymentProvider   String?
  providerPaymentId String?
  refundedAmount    Float    @default(0)
  refundedAt        DateTime?
  refundMode        String?
  subtotal          Float
  shipping          Float    @default(0)
  total             Float
  totalHT           Float    @default(0)
  vatRate           Float    @default(20)
  vatAmount         Float    @default(0)
  totalTTC          Float    @default(0)
  currency          String   @default("EUR")
  customerEmail     String?
  billingAddress    Json?
  isB2B             Boolean  @default(false)
  vatNumber         String?
  proInvoiceNumber  String?
  proInvoiceUrl     String?
  invoiceNumber     String?
  invoiceUrl        String?
  draftShareTokenHash String? @unique
  draftShareSentAt DateTime?
  draftShareExpiresAt DateTime?
  draftShareLastAccessedAt DateTime?
  draftShareConvertedAt DateTime?
  channel           String   @default("online")
  terminalId        String?
  posSessionId      String?
  posPaymentStatus  String?
  posPaidAt         DateTime?
  posCashierId      String?
  posCashierEmail   String?
  promoCodeId       String?
  promotionId       String?
  discountAmount    Float    @default(0)
  orderDiscountType String?
  orderDiscountValue Float?
  discountTotal     Float    @default(0)
  notes             String?
  stockRestored     Boolean  @default(false) // true si le stock a déjà été réintégré (annulation/suppression)
  relayPointId      String?  // ID du point relais Mondial Relay sélectionné au checkout
  relayPointName    String?  // Nom du point relais (ex. "TABAC PRESSE DU MARCHE")
  relayPointAddress String?  // Adresse complète du point relais (ex. "12 RUE DU MARCHE, 75001 PARIS")
  itemsLastModifiedAt DateTime? // Date de dernière modification des articles (pour badge "Facture à régénérer")
  commercialDiscountAmount Float?   // Montant de la remise commerciale appliquée (mode gift)
  commercialDiscountLabel  String?  // Libellé de la remise commerciale (ex: "Remise commerciale")
  paidAmount               Float    @default(0) // Montant réellement encaissé (paiement initial + compléments confirmés via webhook)
  pendingComplementAmount  Float?   // Montant du complément en attente de paiement (lien Mollie envoyé, non encore payé)
  pendingComplementPaymentId String? // ID du paiement Mollie du complément en attente
  paymentDueDate    DateTime? // Date d'échéance de paiement fixée par l'admin sur les brouillons/commandes en attente
  paymentReminderStage Int @default(0) // Stade de relance : 0=aucune, 1=J-3, 2=jour J, 3=J+3
  lastPaymentReminderAt DateTime? // Date d'envoi de la dernière relance de paiement
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer        Customer?        @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  shippingAddress ShippingAddress?
  shipment        Shipment?
  promoCode       PromoCode?       @relation(fields: [promoCodeId], references: [id])
  promotion       Promotion?      @relation(fields: [promotionId], references: [id])
  posSession     PosSession?     @relation(fields: [posSessionId], references: [id])

  @@index([status])
  @@index([customerId])
  @@index([channel])
  @@index([invoiceNumber])
  @@index([draftShareSentAt])
  @@index([terminalId])
  @@index([posSessionId])
  @@index([promoCodeId])
  @@index([promotionId])
  @@index([paymentDueDate])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String?
  variantId      String?
  variantLabel   String?
  name           String
  price          Float
  quantity       Int
  image          String  @default("")
  discountAmount    Float   @default(0)
  lineDiscountType  String?
  lineDiscountValue Float?
  isCustomSale      Boolean @default(false)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([variantId])
}

model Shipment {
  id                  String     @id @default(cuid())
  orderId             String     @unique
  order               Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier             String // 'colissimo', 'mondial_relay', 'colissimo_international'
  carrierShipmentId   String?
  trackingNumber      String?
  trackingUrl         String?
  packagingId         Int?
  packaging           Packaging? @relation(fields: [packagingId], references: [id])
  totalWeightG        Int?
  offerId             String?
  serviceCode         String?
  deliveryMode        String?
  relayPointId        String?
  labelPriceCents     Int?
  labelCurrency       String?    @default("EUR")
  insuranceValueCents Int?
  labelPdfBase64      String?
  labelFormat         String?
  labelSource         String?
  labelStatus         String?
  labelGeneratedAt    DateTime?
  carrierRawResponse  Json?
  lastTrackingStatus  String?
  lastTrackingSyncAt  DateTime?
  shippedAt           DateTime?
  shippedBy           String? // email admin
  createdAt           DateTime   @default(now())

  @@index([carrier])
  @@index([labelStatus])
  @@index([offerId])
  @@index([shippedAt])
}

model ShippingAddress {
  id         String  @id @default(cuid())
  orderId    String  @unique
  firstName  String
  lastName   String
  address    String
  city       String
  postalCode String
  country    String  @default("France")
  extension  String? @default("")
  phone      String? @default("")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── AVIS ────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  productId String
  author    String
  email     String?
  rating    Int
  comment   String
  verified  Boolean  @default(false)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── WISHLIST ────────────────────────────────────────────────
model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

// ─── ADMIN ───────────────────────────────────────────────────
model PasswordResetToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role        String       @default("admin") // admin, superadmin
  posSessions PosSession[]
  createdAt   DateTime     @default(now())
  updatedAt DateTime @updatedAt
}

model PosSession {
  id          String    @id @default(cuid())
  adminId     String
  admin       Admin     @relation(fields: [adminId], references: [id])
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  terminalId  String
  totalSales  Float     @default(0)
  totalOrders Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders Order[]

  @@index([adminId])
  @@index([terminalId])
  @@index([openedAt])
  @@index([closedAt])
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  prefix      String
  permissions String[]
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([key])
  @@index([prefix])
  @@index([isActive])
}

// ─── BLOG ────────────────────────────────────────────────────
model MarketingCampaign {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  type            String
  objective       String
  audience        String
  status          String          @default("draft")
  tone            String          @default("expert")
  channels        String[]        @default([])
  productIds      String[]        @default([])
  content         Json?
  generatedAssets Json?
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  emailCampaigns  EmailCampaign[]
  promoCodes      PromoCode[]
  blogPosts       BlogPost[]

  @@index([status])
  @@index([type])
}
model PromoCode {
  id          String             @id @default(cuid())
  code        String             @unique
  label       String
  description String?
  type        String
  value       Float
  minAmount   Float?
  maxUses     Int?
  usedCount   Int                @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  active      Boolean            @default(true)
  campaignId  String?
  campaign    MarketingCampaign? @relation(fields: [campaignId], references: [id])
  orders      Order[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([active])
  @@index([campaignId])
}

// ─── PROMOTIONS SHOPIFY-LIKE ───────────────────────────────────
model Promotion {
  id               String   @id @default(cuid())
  code             String?  @unique
  name             String
  description      String?
  method           String   @default("code") // code, automatic
  type             String // percentage, fixed_amount, free_shipping, buy_x_get_y
  value            Float?
  valueType        String?  @default("percentage")
  appliesTo        String   @default("all") // all, products, categories
  productIds       String[] @default([])
  categoryIds      String[] @default([])
  minOrderAmount   Float?
  minQuantity      Int?
  customerType     String   @default("all") // all, b2c, b2b
  usageLimit       Int?
  usagePerCustomer Int?     @default(1)
  usageCount       Int      @default(0)
  stackable        Boolean  @default(false)
  isActive         Boolean  @default(true)
  startsAt         DateTime?
  endsAt           DateTime?
  createdBy        String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orders           Order[]
  usages           PromotionUsage[]

  @@index([code])
  @@index([method])
  @@index([isActive])
  @@index([startsAt, endsAt])
}

model PromotionUsage {
  id             String   @id @default(cuid())
  promotionId    String
  orderId        String?
  customerId     String?
  customerEmail  String?
  discountAmount Float
  usedAt         DateTime @default(now())

  promotion      Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@index([customerId])
  @@index([orderId])
}

model EmailCampaign {
  id              String             @id @default(cuid())
  campaignId      String?
  campaign        MarketingCampaign? @relation(fields: [campaignId], references: [id])
  name            String
  subject         String
  preheader       String?
  htmlContent     String
  textContent     String?
  senderName      String?
  senderEmail     String?
  brevoCampaignId Int?
  brevoListId     Int?
  segment         String?
  status          String             @default("draft")
  scheduledAt     DateTime?
  sentAt          DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([campaignId])
}

model BlogPost {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  excerpt         String
  content         String
  coverImage      String?
  categorySlug    String
  tags            String[]           @default([])
  metaTitle       String?
  metaDescription String?
  status          String             @default("draft")
  publishedAt     DateTime?
  campaignId      String?
  campaign        MarketingCampaign? @relation(fields: [campaignId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([categorySlug])
  @@index([campaignId])
}

model BlogArticle {
  id                 String        @id @default(cuid())
  slug               String        @unique
  title              String
  excerpt            String        @db.Text
  content            String        @db.Text
  coverImage         String?
  category           String
  tags               String[]      @default([])
  readTime           Int           @default(1)
  seoMetaTitle       String?
  seoMetaDescription String?
  seoKeywords        String[]      @default([])
  status             String        @default("draft")
  publishedAt        DateTime?
  viewCount          Int           @default(0)
  linkedProductIds   String[]      @default([])
  sourceDraftId      String?       @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  sourceDraft ContentDraft? @relation(fields: [sourceDraftId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([category])
  @@index([publishedAt])
  @@index([createdAt])
}

model MarketingSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CATÉGORIES ──────────────────────────────────────────────
model Category {
  id              String  @id @default(cuid())
  name            String
  slug            String  @unique
  description     String  @default("")
  image           String  @default("")
  parentSlug      String  @default("")
  order           Int     @default(0)
  isActive        Boolean @default(true)
  metaTitle       String  @default("")
  metaDescription String  @default("")
}

// ─── NEWSLETTER ──────────────────────────────────────────────
model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================
// HERMES AGENT - Marketing AI
// ============================================
model HermesConversation {
  id        String   @id @default(cuid())
  title     String?
  channel   String   @default("workspace")
  status    String   @default("active")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages      HermesMessage[]
  contentDrafts ContentDraft[]
  campaignPlans CampaignPlan[]

  @@index([channel])
  @@index([status])
  @@index([createdAt])
}

model HermesMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  module         String?
  model          String?
  tokensInput    Int?
  tokensOutput   Int?
  durationMs     Int?
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation  HermesConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contentDrafts ContentDraft[]

  @@index([conversationId])
  @@index([createdAt])
}

model HermesTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  module    String
  prompt    String   @db.Text
  variables Json?
  isActive  Boolean  @default(true)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module])
  @@index([isActive])
}

model ContentDraft {
  id                 String    @id @default(cuid())
  type               String
  title              String
  content            String    @db.Text
  status             String    @default("draft")
  seoMeta            Json?
  seoMetaTitle       String?
  seoMetaDescription String?
  seoKeywords        String[]  @default([])
  seoSlug            String?
  metadata           Json?
  conversationId     String?
  messageId          String?
  campaignPlanId     String?
  publishedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  conversation HermesConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      HermesMessage?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  campaignPlan CampaignPlan?       @relation(fields: [campaignPlanId], references: [id], onDelete: SetNull)
  blogArticle  BlogArticle?

  @@index([type])
  @@index([status])
  @@index([conversationId])
  @@index([messageId])
  @@index([campaignPlanId])
  @@index([publishedAt])
  @@index([createdAt])
}

model CampaignPlan {
  id                  String    @id @default(cuid())
  name                String
  targetAudience      String
  brevoListIds        Int[]     @default([])
  subject             String
  preheader           String?
  htmlContent         String?   @db.Text
  strategyBrief       String?   @db.Text
  estimatedROI        String?
  scheduledAt         DateTime?
  status              String    @default("draft")
  brevoCampaignId     Int?
  sentAt              DateTime?
  metricsSent         Int?
  metricsDelivered    Int?
  metricsOpened       Int?
  metricsClicked      Int?
  metricsUnsubscribed Int?
  metricsBounced      Int?
  conversationId      String?
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  conversation HermesConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  drafts       ContentDraft[]

  @@index([status])
  @@index([targetAudience])
  @@index([scheduledAt])
  @@index([sentAt])
  @@index([conversationId])
  @@index([createdAt])
}

// ============================================
// HERMES PHASE 4 - Image Generator + Analytics
// ============================================
model HermesImage {
  id             String   @id @default(cuid())
  prompt         String   @db.Text
  negativePrompt String?  @db.Text
  model          String
  replicateId    String?
  status         String   @default("pending")
  replicateUrl   String?
  cloudinaryUrl  String?
  cloudinaryId   String?
  width          Int      @default(1024)
  height         Int      @default(1024)
  aspectRatio    String   @default("1:1")
  format         String   @default("webp")
  category       String?
  tags           String[] @default([])
  conversationId String?
  messageId      String?
  durationMs     Int?
  costUsd        Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model MarketingKPI {
  id                  String   @id @default(cuid())
  date                DateTime
  source              String
  emailsSent          Int?
  emailsOpened        Int?
  emailsClicked       Int?
  emailsBounced       Int?
  emailsUnsubs        Int?
  blogPostsPublished  Int?
  socialPostsCreated  Int?
  productDescsUpdated Int?
  hermesConversations Int?
  hermesMessages      Int?
  hermesTokensUsed    Int?
  hermesCostUsd       Float?
  imagesGenerated     Int?
  imagesCostUsd       Float?
  metadata            Json?
  createdAt           DateTime @default(now())

  @@unique([date, source])
  @@index([date])
  @@index([source])
}
