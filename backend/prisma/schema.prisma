// ============================================================
// BARBER PARADISE — Schéma Prisma (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PRODUITS ────────────────────────────────────────────────
model Product {
  id               String   @id @default(cuid())
  handle           String   @unique
  name             String
  slug             String   @unique
  brand            String
  brandId          Int?
  category         String
  subcategory      String
  subsubcategory   String   @default("")
  price            Float
  priceProEur      Float? // Prix pro HT — null = même prix que B2C
  originalPrice    Float?
  images           String // JSON array
  imageAlts        String   @default("[]") // JSON array of alt texts matching images order
  description      String
  shortDescription String
  features         String   @default("[]") // JSON array
  inStock          Boolean  @default(true)
  stockCount       Int      @default(0)
  weightG          Int? // Poids en grammes
  lengthCm         Float? // Longueur cm
  widthCm          Float? // Largeur cm
  heightCm         Float? // Hauteur cm
  isFragile        Boolean  @default(false)
  isLiquid         Boolean  @default(false)
  isAerosol        Boolean  @default(false)
  requiresGlass    Boolean  @default(false)
  logisticNote     String? // Note spéciale ex: "ne pas coucher"
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  isNew            Boolean  @default(false)
  isPromo          Boolean  @default(false)
  tags             String   @default("[]") // JSON array
  status           String   @default("active") // active, draft, archived
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  brandRef   Brand?           @relation(fields: [brandId], references: [id])
  orderItems OrderItem[]
  reviews    Review[]
  variants   ProductVariant[]

  @@index([category])
  @@index([subcategory])
  @@index([brand])
  @@index([brandId])
  @@index([status])
}

// ─── EMBALLAGES LOGISTIQUES ───────────────────────────────────
model Packaging {
  id                Int     @id @default(autoincrement())
  name              String // ex: "Carton S", "Enveloppe bulle", "Carton renforcé L"
  type              String // 'carton', 'enveloppe', 'tube'
  lengthCm          Float
  widthCm           Float
  heightCm          Float
  internalVolumeCm3 Float // volume utile calculé
  maxWeightG        Int // poids max supporté
  selfWeightG       Int // poids du carton vide
  costEur           Float // coût unitaire du carton
  stock             Int     @default(0)
  isReinforced      Boolean @default(false)
  isActive          Boolean @default(true)

  shipments Shipment[]
}

// ─── MARQUES ─────────────────────────────────────────────────
model Brand {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  bannerImage String?
  website     String?
  createdAt   DateTime @default(now())

  products Product[]
}

// ─── VARIANTES PRODUIT ────────────────────────────────────────────
model ProductVariant {
  id          String  @id @default(cuid())
  productId   String
  name        String // ex: "Rouge", "L", "Rouge / L"
  type        String // "color" | "size" | "other"
  color       String  @default("") // nom de la couleur
  colorHex    String  @default("") // code hexa ex: #FF0000
  size        String  @default("") // ex: "S", "M", "L", "XL"
  price       Float? // si null, utilise le prix du produit parent
  priceProEur Float? // Prix pro HT — null = utilise le prix pro du produit parent
  stock       Int     @default(0)
  inStock     Boolean @default(true)
  sku         String  @default("")
  image       String  @default("") // image spécifique à la variante
  order       Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── CLIENTS ─────────────────────────────────────────────────
model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses           Address[]
  orders              Order[]
  wishlist            WishlistItem[]
  passwordResetTokens PasswordResetToken[]
  proAccount          ProAccount?
}

model ProAccount {
  id              String    @id @default(cuid())
  customerId      String    @unique
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  companyName     String
  siret           String?
  vatNumber       String?
  activity        String
  phone           String
  status          String    @default("pending") // pending, approved, rejected
  rejectionReason String?
  approvedAt      DateTime?
  approvedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─── ADRESSES ────────────────────────────────────────────────
model Address {
  id         String   @id @default(cuid())
  customerId String
  firstName  String
  lastName   String
  address    String
  extension  String?  @default("")
  city       String
  postalCode String
  country    String   @default("France")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ─── COMMANDES ───────────────────────────────────────────────
model Order {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  customerId        String?
  email             String
  status            String   @default("pending") // pending, pending_payment, paid, processing, shipped, delivered, cancelled
  paymentMethod     String?
  paymentProvider   String?
  providerPaymentId String?
  subtotal          Float
  shipping          Float    @default(0)
  total             Float
  totalHT           Float    @default(0)
  vatRate           Float    @default(20)
  vatAmount         Float    @default(0)
  totalTTC          Float    @default(0)
  currency          String   @default("EUR")
  customerEmail     String?
  billingAddress    Json?
  isB2B             Boolean  @default(false)
  vatNumber         String?
  proInvoiceNumber  String?
  proInvoiceUrl     String?
  promoCodeId       String?
  discountAmount    Float    @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer        Customer?        @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  shippingAddress ShippingAddress?
  shipment        Shipment?
  promoCode       PromoCode?       @relation(fields: [promoCodeId], references: [id])

  @@index([status])
  @@index([customerId])
  @@index([promoCodeId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int
  image     String @default("")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Shipment {
  id             String     @id @default(cuid())
  orderId        String     @unique
  order          Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier        String // 'colissimo', 'mondial_relay', 'colissimo_international'
  trackingNumber String?
  packagingId    Int?
  packaging      Packaging? @relation(fields: [packagingId], references: [id])
  totalWeightG   Int?
  shippedAt      DateTime?
  shippedBy      String? // email admin
  createdAt      DateTime   @default(now())

  @@index([carrier])
  @@index([shippedAt])
}

model ShippingAddress {
  id         String  @id @default(cuid())
  orderId    String  @unique
  firstName  String
  lastName   String
  address    String
  city       String
  postalCode String
  country    String  @default("France")
  extension  String? @default("")
  phone      String? @default("")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── AVIS ────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  productId String
  author    String
  email     String?
  rating    Int
  comment   String
  verified  Boolean  @default(false)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── WISHLIST ────────────────────────────────────────────────
model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

// ─── ADMIN ───────────────────────────────────────────────────
model PasswordResetToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin") // admin, superadmin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── BLOG ────────────────────────────────────────────────────
model MarketingCampaign {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  type            String
  objective       String
  audience        String
  status          String          @default("draft")
  tone            String          @default("expert")
  channels        String[]        @default([])
  productIds      String[]        @default([])
  content         Json?
  generatedAssets Json?
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  emailCampaigns  EmailCampaign[]
  promoCodes      PromoCode[]
  blogPosts       BlogPost[]

  @@index([status])
  @@index([type])
}

model PromoCode {
  id          String             @id @default(cuid())
  code        String             @unique
  label       String
  description String?
  type        String
  value       Float
  minAmount   Float?
  maxUses     Int?
  usedCount   Int                @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  active      Boolean            @default(true)
  campaignId  String?
  campaign    MarketingCampaign? @relation(fields: [campaignId], references: [id])
  orders      Order[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([active])
  @@index([campaignId])
}

model EmailCampaign {
  id              String             @id @default(cuid())
  campaignId      String?
  campaign        MarketingCampaign? @relation(fields: [campaignId], references: [id])
  name            String
  subject         String
  preheader       String?
  htmlContent     String
  textContent     String?
  senderName      String?
  senderEmail     String?
  brevoCampaignId Int?
  brevoListId     Int?
  segment         String?
  status          String             @default("draft")
  scheduledAt     DateTime?
  sentAt          DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([campaignId])
}

model BlogPost {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  excerpt         String
  content         String
  coverImage      String?
  categorySlug    String
  tags            String[]           @default([])
  metaTitle       String?
  metaDescription String?
  status          String             @default("draft")
  publishedAt     DateTime?
  campaignId      String?
  campaign        MarketingCampaign? @relation(fields: [campaignId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([categorySlug])
  @@index([campaignId])
}

model MarketingSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CATÉGORIES ──────────────────────────────────────────────
model Category {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String @default("")
  image       String @default("")
  parentSlug  String @default("")
  order       Int    @default(0)
}
