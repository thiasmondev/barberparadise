// ============================================================
// BARBER PARADISE — Schéma Prisma (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PRODUITS ────────────────────────────────────────────────
model Product {
  id              String   @id @default(cuid())
  handle          String   @unique
  name            String
  slug            String   @unique
  brand           String
  brandId         Int?
  category        String
  subcategory     String
  subsubcategory  String   @default("")
  price           Float
  originalPrice   Float?
  images          String   // JSON array
  imageAlts        String   @default("[]") // JSON array of alt texts matching images order
  description     String
  shortDescription String
  features        String   @default("[]") // JSON array
  inStock         Boolean  @default(true)
  stockCount      Int      @default(0)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  isNew           Boolean  @default(false)
  isPromo         Boolean  @default(false)
  tags            String   @default("[]") // JSON array
  status          String   @default("active") // active, draft, archived
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brandRef   Brand?         @relation(fields: [brandId], references: [id])
  orderItems OrderItem[]
  reviews    Review[]
  variants   ProductVariant[]

  @@index([category])
  @@index([subcategory])
  @@index([brand])
  @@index([brandId])
  @@index([status])
}

// ─── MARQUES ─────────────────────────────────────────────────
model Brand {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  logo        String?
  bannerImage String?
  website     String?
  createdAt   DateTime  @default(now())

  products    Product[]
}

// ─── VARIANTES PRODUIT ────────────────────────────────────────────
model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String  // ex: "Rouge", "L", "Rouge / L"
  type      String  // "color" | "size" | "other"
  color     String  @default("") // nom de la couleur
  colorHex  String  @default("") // code hexa ex: #FF0000
  size      String  @default("") // ex: "S", "M", "L", "XL"
  price     Float?  // si null, utilise le prix du produit parent
  stock     Int     @default(0)
  inStock   Boolean @default(true)
  sku       String  @default("")
  image     String  @default("") // image spécifique à la variante
  order     Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── CLIENTS ─────────────────────────────────────────────────
model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses           Address[]
  orders              Order[]
  wishlist            WishlistItem[]
  passwordResetTokens PasswordResetToken[]
}

// ─── ADRESSES ────────────────────────────────────────────────
model Address {
  id         String   @id @default(cuid())
  customerId String
  firstName  String
  lastName   String
  address    String
  extension  String?  @default("")
  city       String
  postalCode String
  country    String   @default("France")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ─── COMMANDES ───────────────────────────────────────────────
model Order {
  id         String      @id @default(cuid())
  orderNumber String     @unique
  customerId String?
  email      String
  status     String      @default("pending") // pending, pending_payment, paid, processing, shipped, delivered, cancelled
  paymentMethod     String?
  paymentProvider   String?
  providerPaymentId String?
  subtotal   Float
  shipping   Float       @default(0)
  total      Float
  totalHT    Float       @default(0)
  vatRate    Float       @default(20)
  vatAmount  Float       @default(0)
  totalTTC   Float       @default(0)
  currency   String      @default("EUR")
  customerEmail String?
  billingAddress Json?
  isB2B      Boolean     @default(false)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  customer       Customer?   @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  shippingAddress ShippingAddress?

  @@index([status])
  @@index([customerId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int
  image     String  @default("")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model ShippingAddress {
  id         String @id @default(cuid())
  orderId    String @unique
  firstName  String
  lastName   String
  address    String
  city       String
  postalCode String
  country    String @default("France")
  extension  String? @default("")
  phone      String? @default("")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── AVIS ────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  productId String
  author    String
  email     String?
  rating    Int
  comment   String
  verified  Boolean  @default(false)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── WISHLIST ────────────────────────────────────────────────
model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

// ─── ADMIN ───────────────────────────────────────────────────
model PasswordResetToken {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin") // admin, superadmin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── BLOG ────────────────────────────────────────────────────
model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  content   String
  image     String
  author    String
  category  String
  readTime  Int      @default(5)
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CATÉGORIES ──────────────────────────────────────────────
model Category {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String @default("")
  image       String @default("")
  parentSlug  String @default("")
  order       Int    @default(0)
}
